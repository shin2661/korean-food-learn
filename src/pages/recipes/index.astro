---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DifficultyBadge from '../../components/DifficultyBadge.astro';
import { getDB } from '../../lib/db';
import { recipes, categories } from '../../../db/schema';
import { eq, and, lte } from 'drizzle-orm';

export const prerender = false;

const db = getDB(Astro.locals);

const difficulty = Astro.url.searchParams.get('difficulty') ?? '';
const maxTime    = Astro.url.searchParams.get('time') ?? '';
const category   = Astro.url.searchParams.get('category') ?? '';

const conditions = [eq(recipes.published, true)];
if (difficulty) conditions.push(eq(recipes.difficulty, difficulty));
if (maxTime)    conditions.push(lte(recipes.cookingTime, parseInt(maxTime)));
if (category) {
  const [cat] = await db.select().from(categories).where(eq(categories.slug, category)).limit(1);
  if (cat) conditions.push(eq(recipes.categoryId, cat.id));
}

const allRecipes = await db
  .select()
  .from(recipes)
  .where(and(...conditions))
  .orderBy(recipes.titleEn);

const allCategories = await db.select().from(categories);
---

<BaseLayout
  title="Korean Recipes | Learn Korean Through Cooking"
  description="Browse authentic Korean recipes with built-in language lessons. Every recipe teaches you Korean vocabulary, phrases, and grammar."
>

  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">All Recipes</span>
      <h1>Cook & Learn Korean</h1>
      <p>Every recipe is a language lesson. Pick one and start cooking.</p>
    </div>
  </div>

  <div class="container page-body">

    <!-- Filters -->
    <form class="filters" method="get">
      <div class="filter-group">
        <label>Difficulty</label>
        <select name="difficulty" onchange="this.form.submit()">
          <option value="" selected={!difficulty}>All levels</option>
          <option value="easy"   selected={difficulty === 'easy'}>Easy</option>
          <option value="medium" selected={difficulty === 'medium'}>Medium</option>
          <option value="hard"   selected={difficulty === 'hard'}>Hard</option>
        </select>
      </div>
      <div class="filter-group">
        <label>Max cooking time</label>
        <select name="time" onchange="this.form.submit()">
          <option value=""   selected={!maxTime}>Any time</option>
          <option value="20" selected={maxTime === '20'}>Under 20 min</option>
          <option value="40" selected={maxTime === '40'}>Under 40 min</option>
          <option value="60" selected={maxTime === '60'}>Under 1 hour</option>
        </select>
      </div>
      {allCategories.length > 0 && (
        <div class="filter-group">
          <label>Category</label>
          <select name="category" onchange="this.form.submit()">
            <option value="" selected={!category}>All categories</option>
            {allCategories.map(cat => (
              <option value={cat.slug} selected={category === cat.slug}>{cat.nameEn}</option>
            ))}
          </select>
        </div>
      )}
      {(difficulty || maxTime || category) && (
        <a href="/recipes" class="clear-filter">✕ Clear filters</a>
      )}
    </form>

    <p class="result-count">
      {allRecipes.length} recipe{allRecipes.length !== 1 ? 's' : ''} found
    </p>

    <!-- Grid -->
    {allRecipes.length > 0 ? (
      <div class="recipe-grid">
        {allRecipes.map(recipe => (
          <a href={`/recipes/${recipe.slug}`} class="recipe-card">
            <div class="card-img">
              {recipe.imageUrl
                ? <img src={recipe.imageUrl} alt={recipe.titleEn} loading="lazy" />
                : <div class="card-placeholder">🍲</div>
              }
              <div class="card-badge">
                <DifficultyBadge difficulty={recipe.difficulty as 'easy'|'medium'|'hard'} />
              </div>
            </div>
            <div class="card-body">
              <div class="card-kr">{recipe.titleKr}</div>
              <h2 class="card-title">{recipe.titleEn}</h2>
              <p class="card-desc">{recipe.description?.slice(0, 90)}...</p>
              <div class="card-meta">
                <span>⏱ {recipe.cookingTime} min</span>
                <span>🍽 {recipe.servings} servings</span>
                {recipe.region && <span>📍 {recipe.region}</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty">
        <p>No recipes found. Try adjusting your filters.</p>
        <a href="/recipes">Clear all filters</a>
      </div>
    )}
  </div>

</BaseLayout>

<style>
.page-hero {
  background: linear-gradient(135deg, #1A1A1A, #2d1a18);
  padding: 5rem 0 3rem;
  margin-bottom: 3rem;
}
.page-hero .eyebrow {
  display: block;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #C0392B;
  margin-bottom: 0.5rem;
}
.page-hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: 3rem;
  color: #fff;
  margin: 0 0 0.75rem;
}
.page-hero p {
  font-family: 'DM Sans', sans-serif;
  color: #aaa;
  font-size: 1rem;
  margin: 0;
}
.container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
.page-body { padding-bottom: 5rem; }

.filters {
  display: flex;
  align-items: flex-end;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 1.5rem;
  padding: 1.25rem;
  background: #fff;
  border: 1px solid #e8e4de;
  border-radius: 16px;
}
.filter-group { display: flex; flex-direction: column; gap: 0.35rem; }
.filter-group label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: #aaa;
}
.filter-group select {
  padding: 0.55rem 0.9rem;
  border: 2px solid #e8e4de;
  border-radius: 10px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  color: #333;
  background: #fff;
  cursor: pointer;
  outline: none;
  transition: border-color 0.15s;
}
.filter-group select:focus { border-color: #C0392B; }
.clear-filter {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.85rem;
  color: #C0392B;
  text-decoration: none;
  padding: 0.55rem 0.75rem;
  border-radius: 8px;
  transition: background 0.15s;
  align-self: flex-end;
}
.clear-filter:hover { background: #fff5f5; }

.result-count {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  color: #aaa;
  margin-bottom: 1.5rem;
}
.recipe-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.5rem;
}
.recipe-card {
  background: #fff;
  border-radius: 20px;
  overflow: hidden;
  text-decoration: none;
  border: 1px solid #e8e4de;
  transition: box-shadow 0.2s, transform 0.2s;
  display: block;
}
.recipe-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.1); transform: translateY(-4px); }
.card-img { position: relative; aspect-ratio: 4/3; overflow: hidden; background: #F0E6D3; }
.card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
.recipe-card:hover .card-img img { transform: scale(1.05); }
.card-placeholder { width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:4rem;background:linear-gradient(135deg,#F0E6D3,#e8d5c0); }
.card-badge { position: absolute; top: 0.75rem; left: 0.75rem; }
.card-body { padding: 1.1rem 1.25rem; }
.card-kr { font-family: 'Noto Sans KR', sans-serif; font-size: 0.85rem; font-weight: 700; color: #C0392B; margin-bottom: 0.2rem; }
.card-title { font-family: 'Playfair Display', serif; font-size: 1.2rem; color: #1A1A1A; margin: 0 0 0.5rem; }
.card-desc { font-family: 'DM Sans', sans-serif; font-size: 0.85rem; color: #888; line-height: 1.5; margin: 0 0 0.75rem; }
.card-meta { display: flex; gap: 1rem; font-family: 'DM Sans', sans-serif; font-size: 0.78rem; color: #aaa; flex-wrap: wrap; }
.empty { text-align: center; padding: 5rem 2rem; font-family: 'DM Sans', sans-serif; color: #999; }
.empty a { color: #C0392B; }
</style>
