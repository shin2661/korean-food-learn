---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | MasisnunKorean">
  <div class="not-found">
    <div class="container">
      <div class="kr-404">없다</div>
      <h1>Page Not Found</h1>
      <p class="rom">eopsda — "It doesn't exist"</p>
      <p class="msg">Looks like this page went missing, like the last piece of 삼겹살 at a BBQ.</p>
      <div class="actions">
        <a href="/" class="btn-primary">Go Home</a>
        <a href="/recipes" class="btn-secondary">Browse Recipes</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
.not-found { min-height:70svh;display:flex;align-items:center;justify-content:center;text-align:center; }
.container { max-width:500px;margin:0 auto;padding:2rem 1.5rem; }
.kr-404 { font-family:'Noto Sans KR',sans-serif;font-size:5rem;font-weight:700;color:#C0392B;line-height:1;margin-bottom:0.5rem; }
h1 { font-family:'Playfair Display',serif;font-size:2.5rem;color:#1A1A1A;margin:0 0 0.25rem; }
.rom { font-family:'DM Sans',sans-serif;font-style:italic;color:#aaa;font-size:1rem;margin:0 0 1.25rem; }
.msg { font-family:'DM Sans',sans-serif;color:#666;font-size:1rem;line-height:1.7;margin:0 0 2rem; }
.actions { display:flex;gap:1rem;justify-content:center;flex-wrap:wrap; }
.btn-primary { display:inline-block;padding:0.75rem 1.75rem;background:#C0392B;color:#fff;font-family:'DM Sans',sans-serif;font-weight:600;border-radius:999px;text-decoration:none;transition:background 0.2s; }
.btn-primary:hover { background:#a93226; }
.btn-secondary { display:inline-block;padding:0.75rem 1.75rem;background:transparent;color:#1A1A1A;font-family:'DM Sans',sans-serif;font-weight:600;border-radius:999px;text-decoration:none;border:2px solid #1A1A1A;transition:all 0.2s; }
.btn-secondary:hover { background:#1A1A1A;color:#fff; }
</style>
