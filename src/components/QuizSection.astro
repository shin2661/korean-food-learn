---
interface Quiz {
  id: number;
  type: string;
  difficulty: string;
  question: string;
  options?: string[] | null;
  answer: string;
  explanation?: string | null;
}

interface Props {
  quizzes: Quiz[];
}

const { quizzes } = Astro.props;
---

<section class="quiz-section" id="quizSection">
  <div class="quiz-header">
    <h2>🧠 Quiz Time</h2>
    <p>Test what you've learned from this recipe</p>
  </div>

  <div class="quiz-progress">
    <div class="progress-bar">
      <div class="progress-fill" id="progressFill" style="width: 0%"></div>
    </div>
    <span class="progress-text" id="progressText">0 / {quizzes.length}</span>
  </div>

  <div class="quiz-cards">
    {quizzes.map((quiz, idx) => (
      <div class="quiz-card" data-quiz-idx={idx} data-answer={quiz.answer}>
        <div class="quiz-meta">
          <span class={`quiz-type type-${quiz.type}`}>{quiz.type.replace('_', ' ')}</span>
          <span class={`quiz-diff diff-${quiz.difficulty}`}>{quiz.difficulty}</span>
        </div>

        <p class="quiz-question">{quiz.question}</p>

        {quiz.type === 'multiple_choice' && quiz.options && (
          <div class="quiz-options" data-type="multiple_choice">
            {quiz.options.map((opt) => (
              <button class="quiz-option" data-value={opt}>{opt}</button>
            ))}
          </div>
        )}

        {(quiz.type === 'translation' || quiz.type === 'fill_blank') && (
          <div class="quiz-input-wrap" data-type="text">
            <input
              type="text"
              class="quiz-input"
              placeholder="Type your answer..."
              autocomplete="off"
              spellcheck="false"
            />
            <button class="quiz-submit-btn">Check</button>
          </div>
        )}

        <div class="quiz-feedback hidden" id={`feedback-${idx}`}>
          <div class="feedback-result"></div>
          {quiz.explanation && <p class="feedback-explanation">{quiz.explanation}</p>}
        </div>
      </div>
    ))}
  </div>

  <div class="quiz-result hidden" id="quizResult">
    <div class="result-emoji" id="resultEmoji">🎉</div>
    <h3 id="resultTitle">Great job!</h3>
    <p id="resultMsg"></p>
    <button class="retry-btn" id="retryBtn">Try Again</button>
  </div>
</section>

<script>
  const quizCards = document.querySelectorAll<HTMLElement>('.quiz-card');
  const progressFill = document.getElementById('progressFill') as HTMLElement;
  const progressText = document.getElementById('progressText') as HTMLElement;
  const quizResult = document.getElementById('quizResult') as HTMLElement;
  const resultEmoji = document.getElementById('resultEmoji') as HTMLElement;
  const resultTitle = document.getElementById('resultTitle') as HTMLElement;
  const resultMsg = document.getElementById('resultMsg') as HTMLElement;
  const retryBtn = document.getElementById('retryBtn') as HTMLButtonElement;

  const total = quizCards.length;
  let answered = 0;
  let correct = 0;

  function updateProgress() {
    const pct = (answered / total) * 100;
    progressFill.style.width = `${pct}%`;
    progressText.textContent = `${answered} / ${total}`;
    if (answered === total) showResult();
  }

  function showFeedback(card: HTMLElement, idx: number, isCorrect: boolean, correctAnswer: string) {
    const feedback = document.getElementById(`feedback-${idx}`) as HTMLElement;
    const resultDiv = feedback.querySelector('.feedback-result') as HTMLElement;

    feedback.classList.remove('hidden');
    resultDiv.innerHTML = isCorrect
      ? `<span class="correct-mark">✓ Correct!</span>`
      : `<span class="wrong-mark">✗ Correct answer: <strong>${correctAnswer}</strong></span>`;

    answered++;
    if (isCorrect) correct++;
    updateProgress();
  }

  // Multiple choice
  quizCards.forEach((card, idx) => {
    const answer = card.dataset.answer!;
    const options = card.querySelectorAll<HTMLButtonElement>('.quiz-option');

    options.forEach(btn => {
      btn.addEventListener('click', () => {
        if (card.dataset.answered) return;
        card.dataset.answered = '1';

        const isCorrect = btn.dataset.value === answer;
        options.forEach(b => {
          b.disabled = true;
          if (b.dataset.value === answer) b.classList.add('correct');
          else if (b === btn && !isCorrect) b.classList.add('wrong');
        });
        showFeedback(card, idx, isCorrect, answer);
      });
    });

    // Text input
    const submitBtn = card.querySelector<HTMLButtonElement>('.quiz-submit-btn');
    const input = card.querySelector<HTMLInputElement>('.quiz-input');

    submitBtn?.addEventListener('click', () => {
      if (!input || card.dataset.answered) return;
      const userAnswer = input.value.trim().toLowerCase();
      const correctLower = answer.toLowerCase();
      const isCorrect = userAnswer === correctLower ||
        correctLower.includes(userAnswer) ||
        userAnswer.includes(correctLower.split(' ')[0]!);

      card.dataset.answered = '1';
      input.disabled = true;
      submitBtn.disabled = true;
      input.classList.add(isCorrect ? 'input-correct' : 'input-wrong');
      showFeedback(card, idx, isCorrect, answer);
    });

    input?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') submitBtn?.click();
    });
  });

  function showResult() {
    quizResult.classList.remove('hidden');
    const pct = Math.round((correct / total) * 100);
    if (pct === 100) {
      resultEmoji.textContent = '🏆';
      resultTitle.textContent = 'Perfect Score!';
    } else if (pct >= 70) {
      resultEmoji.textContent = '🎉';
      resultTitle.textContent = 'Great job!';
    } else {
      resultEmoji.textContent = '📖';
      resultTitle.textContent = 'Keep practicing!';
    }
    resultMsg.textContent = `You got ${correct} out of ${total} correct (${pct}%)`;
  }

  retryBtn?.addEventListener('click', () => location.reload());
</script>

<style>
.quiz-section {
  margin: 3rem 0;
}
.quiz-header {
  margin-bottom: 1.5rem;
}
.quiz-header h2 {
  font-family: 'Playfair Display', serif;
  font-size: 1.75rem;
  color: #1A1A1A;
  margin: 0 0 0.25rem;
}
.quiz-header p {
  font-family: 'DM Sans', sans-serif;
  color: #888;
  margin: 0;
}
.quiz-progress {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
}
.progress-bar {
  flex: 1;
  height: 6px;
  background: #e8e4de;
  border-radius: 999px;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: #C0392B;
  border-radius: 999px;
  transition: width 0.4s ease;
}
.progress-text {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.85rem;
  font-weight: 600;
  color: #888;
  white-space: nowrap;
}
.quiz-cards {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}
.quiz-card {
  background: #fff;
  border: 1px solid #e8e4de;
  border-radius: 16px;
  padding: 1.5rem;
}
.quiz-meta {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
}
.quiz-type, .quiz-diff {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.7rem;
  font-weight: 600;
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
  text-transform: capitalize;
}
.type-multiple_choice { background: #e0f2fe; color: #0369a1; }
.type-translation     { background: #f0fdf4; color: #166534; }
.type-fill_blank      { background: #faf5ff; color: #6b21a8; }
.type-matching        { background: #fff7ed; color: #c2410c; }
.diff-easy   { background: #dcfce7; color: #166534; }
.diff-medium { background: #fef9c3; color: #854d0e; }
.diff-hard   { background: #fee2e2; color: #991b1b; }

.quiz-question {
  font-family: 'DM Sans', sans-serif;
  font-size: 1.05rem;
  font-weight: 500;
  color: #1A1A1A;
  margin: 0 0 1rem;
  line-height: 1.5;
}
.quiz-options {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.quiz-option {
  width: 100%;
  text-align: left;
  padding: 0.75rem 1rem;
  border-radius: 10px;
  border: 2px solid #e8e4de;
  background: #fff;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.95rem;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s;
}
.quiz-option:hover:not(:disabled) {
  border-color: #C0392B;
  background: #fff5f5;
}
.quiz-option.correct { border-color: #22c55e; background: #f0fdf4; }
.quiz-option.wrong   { border-color: #ef4444; background: #fef2f2; }
.quiz-option:disabled { cursor: default; }

.quiz-input-wrap {
  display: flex;
  gap: 0.5rem;
}
.quiz-input {
  flex: 1;
  padding: 0.75rem 1rem;
  border: 2px solid #e8e4de;
  border-radius: 10px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.95rem;
  outline: none;
  transition: border-color 0.15s;
}
.quiz-input:focus { border-color: #C0392B; }
.quiz-input.input-correct { border-color: #22c55e; background: #f0fdf4; }
.quiz-input.input-wrong   { border-color: #ef4444; background: #fef2f2; }
.quiz-submit-btn {
  padding: 0.75rem 1.25rem;
  background: #C0392B;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.15s;
}
.quiz-submit-btn:hover:not(:disabled) { background: #a93226; }
.quiz-submit-btn:disabled { background: #ccc; cursor: default; }

.quiz-feedback {
  margin-top: 0.75rem;
  padding: 0.75rem 1rem;
  background: #f8f7f5;
  border-radius: 10px;
}
.quiz-feedback.hidden { display: none; }
.correct-mark { color: #16a34a; font-weight: 700; font-family: 'DM Sans', sans-serif; }
.wrong-mark   { color: #dc2626; font-weight: 600; font-family: 'DM Sans', sans-serif; }
.feedback-explanation {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.85rem;
  color: #666;
  margin: 0.4rem 0 0;
  line-height: 1.5;
}

.quiz-result {
  margin-top: 2rem;
  text-align: center;
  padding: 2rem;
  background: linear-gradient(135deg, #fff5f5, #fff9f0);
  border: 2px solid #fecaca;
  border-radius: 20px;
}
.quiz-result.hidden { display: none; }
.result-emoji { font-size: 3rem; margin-bottom: 0.5rem; }
.quiz-result h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem;
  color: #1A1A1A;
  margin: 0 0 0.5rem;
}
.quiz-result p {
  font-family: 'DM Sans', sans-serif;
  color: #666;
  margin: 0 0 1.25rem;
}
.retry-btn {
  padding: 0.75rem 2rem;
  background: #C0392B;
  color: #fff;
  border: none;
  border-radius: 999px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.15s, transform 0.15s;
}
.retry-btn:hover {
  background: #a93226;
  transform: translateY(-1px);
}
</style>
